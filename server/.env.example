# Copy to .env and fill in values:
#   cp .env.example .env

# Required for LangGraph supervisor (ChatOpenAI), Stagehand, OpenAI TTS, OpenAI STT
OPENAI_API_KEY=

# Default LLM for VoicePipeline paths that use getLLMProvider() (supervisor uses OpenAI regardless)
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=

# Desktop + Apple Notes agents — use Console API key (sk-ant-api...). Do not set ANTHROPIC_AUTH_TOKEN unless you need Bearer auth (conflicts with API key).
ANTHROPIC_API_KEY=

# Optional: set empty to override a proxy URL from your shell (server loadEnv uses override). For direct Anthropic, use the line below or omit both.
# ANTHROPIC_BASE_URL=

# Optional: Anthropic computer-use (defaults: Sonnet 4.6 + computer-use-2025-11-24 + computer_20251124 tool)
# Override model/beta together if you pin an older stack (e.g. Sonnet 4.5 + computer-use-2025-01-24).
# ANTHROPIC_COMPUTER_USE_MODEL=claude-sonnet-4-6
# ANTHROPIC_COMPUTER_USE_BETA=computer-use-2025-11-24

# Server port (default 3001)
# PORT=3001

# Skip Stagehand + Elasticsearch; canned socket responses
# TEST=true

# Optional: Cartesia (logged at startup; handler uses OpenAI TTS today)
# CARTESIA_API_KEY=

# Optional: Deepgram live STT (handler uses OpenAI STT today)
# DEEPGRAM_API_KEY=

# Optional: web_search tool in agents
# PERPLEXITY_API_KEY=

# Optional: local SQLite + FTS5 knowledge base (takes precedence over Elasticsearch when set)
# SQLITE_KB_PATH=./data/knowledge.db

# Optional: Elasticsearch knowledge base (used only if SQLITE_KB_PATH is unset)
# ELASTIC_CLOUD_ID=
# ELASTIC_API_KEY=

# Optional: coding agent workspace root
# WORKSPACE_PATH=

# Optional: require this value as x-server-api-key (or Bearer) on POST /api/chat
# and as socket.handshake.auth.token (or x-server-api-key header) for Socket.io
# SERVER_API_KEY=

# Optional: comma-separated browser origins for CORS + Socket.io (default: allow all)
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Browser clients: set the same value (exposed in bundle) so sockets/API work when SERVER_API_KEY is set
# NEXT_PUBLIC_SERVER_API_KEY=   (Next client)
# VITE_SERVER_API_KEY=          (Electron; use only for local demos)
